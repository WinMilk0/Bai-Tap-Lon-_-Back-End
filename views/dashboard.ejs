<%- include('partials/header') %>

    <div class="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="sidebar-header d-flex align-items-center justify-content-center">
                <h4 class="mb-0 fw-bold"><i class="bi bi-tree-fill me-2" style="color: #10b981;"></i>AgriContract</h4>
            </div>
            <ul class="list-unstyled components mt-3">
                <p class="text-muted small text-uppercase mb-2 px-4 fw-bold">Quản lý tổng quan</p>
                <li class="active">
                    <a href="/"><i class="bi bi-speedometer2 me-3 fs-5"></i> Dashboard</a>
                </li>
                <p class="text-muted small text-uppercase mt-4 mb-2 px-4 fw-bold">Nghiệp vụ</p>
                <li>
                    <a href="/farmers"><i class="bi bi-people me-3 fs-5"></i> Hộ nông dân</a>
                </li>
                <li>
                    <a href="/advances"><i class="bi bi-box-seam me-3 fs-5"></i> Cấp phát vật tư</a>
                </li>
                <li>
                    <a href="/settlements"><i class="bi bi-calculator me-3 fs-5"></i> Quyết toán mùa vụ</a>
                </li>
                <p class="text-muted small text-uppercase mt-4 mb-2 px-4 fw-bold">Tài khoản</p>
                <li>
                    <a href="/auth/logout" class="text-danger"><i class="bi bi-box-arrow-right me-3 fs-5"></i> Đăng
                        xuất</a>
                </li>
            </ul>
        </nav>

        <!-- Page Content -->
        <div id="content" class="bg-light">
            <nav class="navbar navbar-expand-lg navbar-custom">
                <div class="container-fluid">
                    <span class="navbar-brand mb-0 h5 fw-bold text-dark">Tổng quan Hệ thống</span>
                    <div class="d-flex align-items-center ms-auto">
                        <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark"
                                id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                                <% if(user.avatar) { %>
                                    <img src="<%= user.avatar %>" alt="User" width="36" height="36" class="rounded-circle me-2 shadow-sm" style="object-fit: cover;">
                                <% } else { %>
                                    <img src="https://ui-avatars.com/api/?name=<%= user.full_name || user.username %>&background=10b981&color=fff&bold=true"
                                        alt="User" width="36" height="36" class="rounded-circle me-2 shadow-sm">
                                <% } %>
                                <strong class="d-none d-md-block">
                                    <%= user.full_name || user.username %>
                                </strong>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2"
                                aria-labelledby="dropdownUser">
                                <li>
                                    <h6 class="dropdown-header">Xin chào, <%= user.username %>!</h6>
                                </li>
                                <li><a class="dropdown-item py-2" href="/profile"><i class="bi bi-person-circle me-2"></i>Hồ sơ của tôi</a></li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li><a class="dropdown-item text-danger py-2" href="/auth/logout"><i
                                            class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <% if(success_msg && success_msg.length> 0) { %>
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <%= success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>

                    <!-- Banner Section -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card bg-dark text-white border-0 shadow-sm overflow-hidden"
                                style="min-height: 180px; position: relative;">
                                <!-- THAY ĐỔI LINK ẢNH BANNER TẠI ĐÂY (Trong thuộc tính src="..." và onerror="...") -->
                                <img src="https://mimosawedding.vn/wp-content/uploads/2022/07/phim-truong-thao-nguyen-hoa-3.jpg"
                                    class="card-img" alt="Agri Banner"
                                    style="object-fit: cover; opacity: 0.6; height: 100%; position: absolute; top:0; left: 0;"
                                    onerror="this.src='https://images.unsplash.com/photo-1500937386664-56d1dfefcb19?auto=format&fit=crop&q=80&w=2670'">
                                <div
                                    class="card-img-overlay d-flex flex-column justify-content-center bg-dark bg-opacity-50">
                                    <div class="container-fluid">
                                        <h2 class="card-title fw-bold mb-1">Hệ Sinh Thái Bao Tiêu Nông Sản</h2>
                                        <p class="card-text fs-5">Minh bạch dòng tiền - Tự động hóa quá trình thu mua.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card shadow-sm border-0 border-start border-success border-4 h-100 rounded-3">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted fw-bold mb-1 text-uppercase small">Tổng Số Nông Dân
                                            </h6>
                                            <h3 class="mb-0 fw-bold text-dark">
                                                <%= locals.stats ? stats.totalFarmers : 0 %>
                                            </h3>
                                        </div>
                                        <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success shadow-sm">
                                            <i class="bi bi-people-fill fs-4"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card shadow-sm border-0 border-start border-warning border-4 h-100 rounded-3">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted fw-bold mb-1 text-uppercase small">Tổng Nợ Vật Tư</h6>
                                            <h3 class="mb-0 fw-bold text-dark">
                                                <%= locals.stats ? stats.totalAdvances.toLocaleString() : 0 %> <span
                                                        class="fs-6 text-muted">VNĐ</span>
                                            </h3>
                                        </div>
                                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning shadow-sm">
                                            <i class="bi bi-piggy-bank-fill fs-4"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card shadow-sm border-0 border-start border-info border-4 h-100 rounded-3">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted fw-bold mb-1 text-uppercase small">Số Lượng Thu Mua
                                            </h6>
                                            <h3 class="mb-0 fw-bold text-dark">
                                                <%= locals.stats ? stats.totalHarvestQuantity.toLocaleString() : 0 %>
                                                    <span class="fs-6 text-muted">kg</span>
                                            </h3>
                                        </div>
                                        <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info shadow-sm">
                                            <i class="bi bi-basket2-fill fs-4"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card shadow-sm border-0 border-start border-danger border-4 h-100 rounded-3">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="text-muted fw-bold mb-1 text-uppercase small">Đã Chi Trả</h6>
                                            <h3 class="mb-0 fw-bold text-dark">
                                                <%= locals.stats ? stats.totalPayout.toLocaleString() : 0 %> <span
                                                        class="fs-6 text-muted">VNĐ</span>
                                            </h3>
                                        </div>
                                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle text-danger shadow-sm">
                                            <i class="bi bi-cash-stack fs-4"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 rounded-3 mb-4">
                        <div class="card-header bg-white py-3 border-bottom-0">
                            <h6 class="mb-0 fw-bold text-dark"><i
                                    class="bi bi-info-circle-fill me-2 text-primary"></i>Hướng dẫn sử dụng hệ thống</h6>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">Chào mừng đến với hệ thống <strong>AgriContract</strong>. Dưới đây là
                                quy trình quản lý hợp đồng bao tiêu nông sản tổng thể:</p>
                            <div class="row mt-4">
                                <div class="col-md-4 mb-3">
                                    <div class="p-4 bg-light rounded-3 h-100 border">
                                        <h5 class="fw-bold text-dark mb-3"><i
                                                class="bi bi-1-circle-fill text-primary me-2"></i>Hộ nông dân</h5>
                                        <p class="text-muted mb-0 small">Quản lý danh sách các hộ nông dân theo từng
                                            thôn/xã. Đây là cơ sở dữ liệu quan trọng để tiến hành xuất vật tư và thu mua
                                            nông sản sau này.</p>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <div class="p-4 bg-light rounded-3 h-100 border">
                                        <h5 class="fw-bold text-dark mb-3"><i
                                                class="bi bi-2-circle-fill text-warning me-2"></i>Cấp phát vật tư</h5>
                                        <p class="text-muted mb-0 small">Ghi nhận các lần xuất kho cho nông dân mượn
                                            giống hoặc phân bón. Hệ thống theo dõi công nợ, đơn giá và tính toán tổng nợ
                                            cho từng hộ.</p>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <div class="p-4 bg-light rounded-3 h-100 border">
                                        <h5 class="fw-bold text-dark mb-3"><i
                                                class="bi bi-3-circle-fill text-success me-2"></i>Quyết toán thu mua
                                        </h5>
                                        <p class="text-muted mb-0 small">Sau vụ thu hoạch, nông dân nhập nông sản. Hệ
                                            thống tự động khấu trừ nợ vật tư tương ứng và tính ra số tiền mặt thực nhận
                                            cuối cùng.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
        </div>
    </div>

    <%- include('partials/footer') %>