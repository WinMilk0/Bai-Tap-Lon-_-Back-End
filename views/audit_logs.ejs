<%- include('partials/header') %>

<div class="wrapper">
    <!-- Sidebar -->
    <nav id="sidebar">
        <div class="sidebar-header d-flex align-items-center justify-content-center">
            <h4 class="mb-0 fw-bold"><i class="bi bi-tree-fill me-2" style="color: #10b981;"></i>AgriContract</h4>
        </div>
        <ul class="list-unstyled components mt-3">
            <p class="text-muted small text-uppercase mb-2 px-4 fw-bold">Quản lý tổng quan</p>
            <li>
                <a href="/"><i class="bi bi-speedometer2 me-3 fs-5"></i> Dashboard</a>
            </li>
            <p class="text-muted small text-uppercase mt-4 mb-2 px-4 fw-bold">Nghiệp vụ</p>
            <li>
                <a href="/farmers"><i class="bi bi-people me-3 fs-5"></i> Hộ nông dân</a>
            </li>
            <li>
                <a href="/advances"><i class="bi bi-box-seam me-3 fs-5"></i> Cấp phát vật tư</a>
            </li>
            <li>
                <a href="/settlements"><i class="bi bi-calculator me-3 fs-5"></i> Quyết toán mùa vụ</a>
            </li>

            <% if (user.role === 'admin') { %>
            <p class="text-muted small text-uppercase mt-4 mb-2 px-4 fw-bold text-danger">Quản trị Hệ Thống</p>
            <li class="active">
                <a href="/audit-logs"><i class="bi bi-shield-lock me-3 fs-5"></i> Lịch Sử Thao Tác</a>
            </li>
            <% } %>

            <p class="text-muted small text-uppercase mt-4 mb-2 px-4 fw-bold">Tài khoản</p>
            <li>
                <a href="/auth/logout" class="text-danger"><i class="bi bi-box-arrow-right me-3 fs-5"></i> Đăng xuất</a>
            </li>
        </ul>
    </nav>

    <!-- Page Content -->
    <div id="content" class="bg-light">
        <nav class="navbar navbar-expand-lg navbar-custom mb-4">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5 fw-bold text-dark">Nhật Ký Hệ Thống (Audit Logs)</span>
                <span class="badge bg-danger rounded-pill px-3 py-2 ms-3"><i class="bi bi-shield-check me-1"></i> ADMIN ONLY</span>
                <div class="d-flex align-items-center ms-auto">
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=<%= user.full_name || user.username %>&background=10b981&color=fff&bold=true" alt="User" width="36" height="36" class="rounded-circle me-2 shadow-sm">
                            <strong class="d-none d-md-block"><%= user.full_name || user.username %></strong>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="dropdownUser">
                            <li><a class="dropdown-item text-danger py-2" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <div class="card shadow-sm border-0 rounded-3 mb-4">
            <div class="card-header bg-dark text-white py-3 border-bottom-0">
                <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-warning"></i>100 Thao tác gần nhất</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Mã Log</th>
                                <th>Người Thực Hiện</th>
                                <th>Hành Động</th>
                                <th>Chi Tiết</th>
                                <th>Thời Gian</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(logs.length === 0) { %>
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">
                                        <i class="bi bi-inbox fs-1 text-light"></i>
                                        <p class="mt-2 mb-0">Chưa có lịch sử thao tác nào.</p>
                                    </td>
                                </tr>
                            <% } else { %>
                                <% logs.forEach(log => { %>
                                    <tr>
                                        <td class="ps-4 text-muted small">#<%= log.id %></td>
                                        <td>
                                            <span class="fw-bold text-primary"><%= log.full_name || log.username %></span>
                                            <div class="text-muted small">ID: <%= log.user_id %></div>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary"><%= log.action %></span>
                                        </td>
                                        <td class="text-dark"><%= log.details %></td>
                                        <td class="text-muted small">
                                            <%= new Date(log.created_at).toLocaleString('vi-VN') %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
